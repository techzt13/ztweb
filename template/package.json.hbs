{
  "name": "{{projectName}}",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    {{#if useTypeScript}}"build": "vue-tsc && vite build",{{else}}"build": "vite build",{{/if}}
    "preview": "vite preview"{{#if useVitest}},
    "test": "vitest"{{/if}}{{#if useE2e}},
    {{#if (eq useE2e "cypress")}}"test:e2e": "cypress open"{{/if}}{{#if (eq useE2e "playwright")}}"test:e2e": "playwright test"{{/if}}{{#if (eq useE2e "nightwatch")}}"test:e2e": "nightwatch"{{/if}}{{/if}}{{#if useEslint}},
    "lint": "eslint ."{{/if}}{{#if usePrettier}},
    "format": "prettier --write ."{{/if}}
  },
  "dependencies": {
    "vue": "^3.4.0"{{#if useRouter}},
    "vue-router": "^4.3.0"{{/if}}{{#if usePinia}},
    "pinia": "^2.1.0"{{/if}}
  },
  "devDependencies": {
    "@vue/compiler-sfc": "^3.4.0",
    "vite": "^5.0.0",
    "vite-plugin-zweb": "file:./vite-plugin-zweb"{{#if useTypeScript}},
    "typescript": "^5.4.0",
    "vue-tsc": "^2.0.0"{{/if}}{{#if useJsx}},
    "@vitejs/plugin-vue-jsx": "^4.0.0"{{/if}}{{#if useVitest}},
    "vitest": "^1.5.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^24.0.0"{{/if}}{{#if (eq useE2e "cypress")}},
    "cypress": "^13.0.0"{{/if}}{{#if (eq useE2e "playwright")}},
    "@playwright/test": "^1.44.0"{{/if}}{{#if (eq useE2e "nightwatch")}},
    "nightwatch": "^3.5.0"{{/if}}{{#if useEslint}},
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.25.0",
    "@eslint/js": "^9.0.0"{{/if}}{{#if usePrettier}},
    "prettier": "^3.2.0"{{/if}}
  }
}
